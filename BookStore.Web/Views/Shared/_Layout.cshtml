<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"] - BookStore Books</title>

    <link rel="stylesheet" href="~/css/shared.css" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>

    <!-- ═══ CSS Variables & Styles ═════════════════════════════════════════════════ -->
    

<body>
    <header>
        <!-- Mobile Menu Overlay -->
        <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>
        
        <!-- Mobile Menu -->
        <div class="mobile-menu" id="mobileMenu">
            <div class="mobile-menu-close" id="mobileMenuClose">
                <i class="fas fa-times"></i>
            </div>
            <div class="mobile-menu-links">
                <a href="@Url.Action("Index", "Shop")" class="mobile-menu-link">All Books</a>
                <a href="@Url.Action("Index", "Shop", new { category = "software" })" class="mobile-menu-link">Software</a>
                <a href="@Url.Action("Index", "Shop", new { category = "ai" })" class="mobile-menu-link">AI & Data</a>
                <a href="@Url.Action("Index", "Shop", new { category = "cyber" })" class="mobile-menu-link">Cybersecurity</a>
            </div>
            <div class="mobile-menu-actions">
                <a href="@Url.Action("Index", "Cart")" class="btn-icon" title="View Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="badge">@ViewBag.CartCount</span>
                </a>
                @if (User.Identity.IsAuthenticated)
                {
                    <a href="@Url.Action("Profile", "Account")" class="mobile-menu-link" title="My Account">
                        <i class="fas fa-user"></i> My Account
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn-primary-sm">
                        <i class="fas fa-sign-in-alt"></i> Sign In
                    </a>
                    <a href="@Url.Action("Register", "Account")" class="btn-primary-sm">
                        <i class="fas fa-user-plus"></i> Sign Up
                    </a>
                }
            </div>
        </div>
        
        <!-- Main Navbar -->
        <nav class="navbar" id="mainNavbar">
            <div class="mobile-toggle" id="mobileMenuBtn">
                <i class="fas fa-bars"></i>
            </div>

            <a href="@Url.Action("Index", "Home")" class="navbar-brand">
                <div class="brand-logo">
                    <i class="fas fa-book-open"></i>
                </div>
                <span>BookStore</span>
            </a>

            <div class="nav-menu">
                <a href="@Url.Action("Index", "Shop")" class="nav-link">All Books</a>
                <a href="@Url.Action("Index", "Shop", new { category = "software" })" class="nav-link">Software</a>
                <a href="@Url.Action("Index", "Shop", new { category = "ai" })" class="nav-link">AI & Data</a>
                <a href="@Url.Action("Index", "Shop", new { category = "cyber" })" class="nav-link">Cybersecurity</a>
            </div>

            <div class="nav-actions">
                <form action="@Url.Action("Search", "Shop")" method="get" class="search-container">
                    <i class="fas fa-search"></i>
                    <input type="text" name="q" placeholder="Search for books..." aria-label="Search">
                </form>

                <a href="@Url.Action("Index", "Cart")" class="btn-icon" title="View Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="badge">@ViewBag.CartCount</span>
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a href="@Url.Action("Profile", "Account")" class="btn-icon" title="My Account">
                        <i class="fas fa-user"></i>
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn-primary-sm">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Sign In</span>
                    </a>
                    <a href="@Url.Action("Register", "Account")" class="btn-primary-sm">
                        <i class="fas fa-user-plus"></i>
                        <span>Sign Up</span>
                    </a>
                }
            </div>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-brand-info">
                <h3><i class="fas fa-book-open"></i> BookStore</h3>
                <p>Egypt's leading tech bookstore. Empowering developers with the best technical literature in the region.</p>
                <div class="social-grid">
                    <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-tiktok"></i></a>
                </div>
            </div>

            <div class="footer-links">
                <h4 class="footer-heading">Quick Links</h4>
                <a href="@Url.Action("Index", "Home")">Home</a>
                <a href="@Url.Action("Index", "Shop")">Browse Shop</a>
                <a href="#">About Us</a>
                <a href="#">Contact Support</a>
            </div>

            <div class="footer-links">
                <h4 class="footer-heading">Legal & Help</h4>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Refund Policy</a>
                <a href="#">Order Tracking</a>
            </div>

            <div class="footer-newsletter">
                <h4 class="footer-heading">Stay Updated</h4>
                <p style="font-size: 0.9rem; color: rgba(255, 255, 255, 0.8); margin-bottom: 1rem;">Get the latest tech book releases delivered to your inbox.</p>
                <div style="display: flex; gap: 0.5rem;">
                    <input type="email" placeholder="Your email" style="padding: 0.6rem; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: var(--radius-sm); flex: 1; outline: none; background: rgba(255, 255, 255, 0.1); color: white;">
                    <button style="background: var(--accent); color: white; border: none; padding: 0.6rem 1rem; border-radius: var(--radius-sm); cursor: pointer; transition: all 0.3s ease;">Join</button>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year BookStore Books. All rights reserved.</p>
            <p>Built for Developers &middot; Egypt</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const navbar = document.getElementById('mainNavbar');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileMenuClose = document.getElementById('mobileMenuClose');
            const mobileMenu = document.getElementById('mobileMenu');
            const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
            let lastScrollTop = 0;
            let isScrolling;
            
            
            function handleScroll() {
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                
                if (scrollTop > 0) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
                
                lastScrollTop = scrollTop;
            }
            
            
            window.addEventListener('scroll', function() {
                window.clearTimeout(isScrolling);
                handleScroll();
                
                isScrolling = setTimeout(function() {
                    handleScroll();
                }, 100);
            });
            
            
            function openMobileMenu() {
                mobileMenu.classList.add('active');
                mobileMenuOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                document.body.style.position = 'fixed';
                document.body.style.width = '100%';
            }
            
            function closeMobileMenu() {
                mobileMenu.classList.remove('active');
                mobileMenuOverlay.classList.remove('active');
                document.body.style.overflow = '';
                document.body.style.position = '';
                document.body.style.width = '';
            }
            
            if (mobileMenuBtn) {
                mobileMenuBtn.addEventListener('click', openMobileMenu);
            }
            
            if (mobileMenuClose) {
                mobileMenuClose.addEventListener('click', closeMobileMenu);
            }
            
            if (mobileMenuOverlay) {
                mobileMenuOverlay.addEventListener('click', closeMobileMenu);
            }
            
           
            document.querySelectorAll('.mobile-menu-link').forEach(link => {
                link.addEventListener('click', function() {
                    closeMobileMenu();
                });
            });
            
           
            function handleResize() {
                if (window.innerWidth > 1024) {
                    closeMobileMenu();
                }
            }
            
            window.addEventListener('resize', handleResize);
            
           
            handleScroll();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>