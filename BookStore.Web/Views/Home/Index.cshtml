    var newArrivals = ViewBag.NewArrivals as List<ProductResultDto> ?? new List<ProductResultDto>();
    var categories = ViewBag.Categories as List<CategoryResultDto> ?? new List<CategoryResultDto>();
    var totalBooks = ViewBag.TotalBooks ?? 0;
    var totalCustomers = ViewBag.TotalCustomers ?? 12000;
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<!-- ══ HERO SECTION ══ -->
<section class="hero-section">
    <div class="hero-bg-overlay"></div>
    <div class="hero-gradient"></div>
    <div class="hero-container">
        <div class="hero-content" data-aos="fade-right">
            <div class="hero-eyebrow">
                <span class="eyebrow-text">★ Egypt's Premier Tech Library</span>
            </div>
            <h1>Empowering Developers<br>Through <em>Great Books</em></h1>
            <p class="hero-description">
                Join <strong>@totalCustomers+</strong> developers in Egypt. From System Design to Artificial Intelligence, 
                we curate the highest quality technical literature to help you build the future.
            </p>
            <div class="hero-btns">
                <a href="@Url.Action("Index", "Shop")" class="btn-gold">
                    <i class="fas fa-book-open"></i> Explore All Books
                </a>
                <a href="#new-arrivals" class="btn-outline-white">
                    <i class="fas fa-sparkles"></i> New Arrivals
