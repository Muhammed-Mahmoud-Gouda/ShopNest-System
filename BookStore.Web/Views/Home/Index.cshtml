            <i class="fas fa-chevron-down"></i>
        </a>
    </div>
</section>

<!-- ══ POPULAR CATEGORIES (Carousel - 4 Cards) ══ -->
<section id="categories" class="section-padding bg-cream">
    <div class="container-xl">
        <div class="section-header">
            <div class="section-title-wrap">
                <span class="subtitle">Browse by Interest</span>
                <h2>Popular Categories</h2>
            </div>
            <a href="@Url.Action("Index", "Shop")" class="view-all-link">
                View All Categories <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        @if (categories.Any())
        {
            <div class="category-carousel-wrapper justify-content-center">
                <!-- Navigation Buttons -->
                <button class="carousel-nav prev-btn" id="catPrev" aria-label="Previous categories" type="button">
                    <i class="fas fa-chevron-left"></i>
                </button>
                
                <div class="category-carousel-track" id="categoryTrack">
                    @foreach (var cat in categories)
                    {
                        <a href="@Url.Action("Index", "Shop", new { categoryId = cat.Id })" class="cat-card-compact" data-aos="fade-up">
                            <div class="cat-img-wrap">
                                <img src="@(string.IsNullOrEmpty(cat.ImagePath) 
                                    ? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?q=80&w=400" 
                                    : cat.ImagePath)" 
                                     alt="@cat.Name" 
                                     loading="lazy"
                                     onerror="this.src='https://images.unsplash.com/photo-1516116216624-53e697fedbea?q=80&w=400'">
                                <div class="cat-overlay"></div>
                            </div>
                            <div class="cat-info">
                                <h4>@cat.Name</h4>
                                <span class="cat-count">@cat.ProductsCount Books</span>
                            </div>
                        </a>
                    }
                </div>
                
                <button class="carousel-nav next-btn" id="catNext" aria-label="Next categories" type="button">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
            
            <!-- Dots Indicator (only if more than 4 categories) -->
            @if (categories.Count > 4)
            {
                <div class="carousel-dots" id="categoryDots">
                    @for (int i = 0; i < Math.Ceiling((double)categories.Count / 4); i++)
                    {
                        <button class="dot @(i == 0 ? "active" : "")" data-index="@i" aria-label="Go to slide @(i+1)" type="button"></button>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-folder-open"></i>
                <p>No categories available yet. Check back soon!</p>
            </div>
        }
    </div>
</section>

